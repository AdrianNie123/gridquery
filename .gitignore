# Data artifacts: rebuilt via `make land`, never committed
data/

# Python
.venv/
__pycache__/
*.pyc

# Secrets: API keys live in .env, never committed (.env.example documents the shape)
.env

# Eval run artifacts: timestamped runs and raw batch output stay local;
# latest.json is committed at the phase gate for provenance
eval/results/*
!eval/results/latest.json

# dlt runtime state
.dlt/secrets.toml
transform/target/
transform/dbt_packages/
transform/logs/
logs/
